# Google Gemini API Key (required for all LLM agents)
GOOGLE_API_KEY=your_google_api_key_here

# Tavily API Key (required for TavilyNewsVerificationAgent)
TAVILY_API_KEY=your_tavily_api_key_here

# Neo4j Database (required for NLP, Risk, Alert, Suggestion agents)
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_neo4j_password
NEO4J_DATABASE=neo4j

# Server Ports
ORCHESTRATOR_PORT=8001
AGUI_PORT=8002

# Agent Ports (each agent runs on its own port)
NEWS_VERIFICATION_PORT=8010
TAVILY_VERIFICATION_PORT=8011
NLP_AGENT_PORT=8012
RISK_AGENT_PORT=8013
SIMILAR_COMPANY_PORT=8014
ALERT_AGENT_PORT=8015
SUGGESTION_AGENT_PORT=8016

# Model Configuration
ORCHESTRATOR_MODEL=gemini-2.5-pro
NLP_MODEL=gemini-2.0-flash
RISK_MODEL=gemini-2.5-flash
ALERT_MODEL=gemini-2.0-flash
SUGGESTION_MODEL=gemini-2.0-flash
VIEW_AGENT_MODEL=gemini-2.5-flash
